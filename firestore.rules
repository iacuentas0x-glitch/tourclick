rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() && userDoc().data.role;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isCompany(agencyId) {
      return role() == 'company' && userDoc().data.agencyId == agencyId;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /agencies/{agencyId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isCompany(agencyId);
    }

    match /tours/{tourId} {
      allow read: if true;
      allow create: if isAdmin() || isCompany(request.resource.data.agencyId);
      allow update: if isAdmin() || isCompany(resource.data.agencyId);
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if signedIn() && request.resource.data.clientId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.clientId == request.auth.uid ||
        isAdmin() ||
        isCompany(resource.data.agencyId)
      );
      allow update: if isAdmin() || isCompany(resource.data.agencyId);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
